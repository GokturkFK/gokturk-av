# GÖKTÜRK-AV — Ortam Değişkenleri
# Bu dosyayı kopyala: cp .env.example .env
# .env asla git'e commit edilmez (.gitignore'da)

# Streamlit UI giriş şifresi
GOKTÜRK_PASSWORD=goktürk2026

# SQLite bulgu veritabanı yolu (Docker: data/ klasörüne mount edilir)
DB_PATH=data/findings.db

# Docker Hub (CD pipeline için — GitHub Secrets'a ekle)
# DOCKERHUB_USERNAME=<kullanıcı_adın>
# DOCKERHUB_TOKEN=<access_token>
